# ──────────────────────────────────────────────
# redevops.io — Agentic Marketing Attribution
# Environment Configuration
# ──────────────────────────────────────────────

# ── LLM / Agent Configuration ──────────────────
# OpenAI-compatible endpoint (OpenAI, Azure, Ollama, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
# Your API key for the LLM provider
OPENAI_API_KEY=sk-placeholder
# Model identifier (e.g. gpt-4o, gpt-4o-mini, claude-3-opus, etc.)
MODEL=gpt-4o

# ── PostHog (Product Analytics) ─────────────────
POSTHOG_HOST=http://localhost:8000
POSTHOG_API_KEY=
POSTHOG_SECRET_KEY=super-secret-key-change-in-production
POSTHOG_DB_PASSWORD=posthog_secret

# ── Matomo (Web Analytics) ──────────────────────
MATOMO_URL=http://localhost:8080
MATOMO_TOKEN_AUTH=
MATOMO_DB_ROOT_PASSWORD=matomo_root_secret
MATOMO_DB_PASSWORD=matomo_secret

# ── Agent Service Runtime ───────────────────────
AGENT_LOG_LEVEL=info
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.1